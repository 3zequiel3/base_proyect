# App
APP_NAME="Base Project API"
APP_VERSION="0.1.0"
APP_ENV="development"

# PostgreSQL
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="base_project"
DB_ECHO="false"

# Optional full URLs. If DATABASE_URL is set, it takes precedence over DB_*.
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/base_project"
# SYNC_DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/base_project"
# MASTER_DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/postgres"

# Local development helpers. Prefer Alembic/provisioning in production.
DB_CREATE_DATABASE="false"
DB_CREATE_TABLES="false"
